# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# --- WhatsApp Cloud API (Phase 0) ---
# From developers.facebook.com > your app > WhatsApp > API Setup
WHATSAPP_TOKEN=          # temporary token to start (24h); we'll swap for a permanent one later
PHONE_NUMBER_ID=         # the "Phone number ID" of the test number
MY_NUMBER=               # your WhatsApp number, country code, digits only e.g. 447700900123

# --- Added in later phases ---
GEMINI_API_KEY=          # aistudio.google.com/apikey (free tier) — Phase 1
GOOGLE_CREDENTIALS_JSON= # service-account JSON for editing the Obsidian vault via Drive — Phase 2/3
VERIFY_TOKEN=            # random string you choose, for the Cloudflare webhook — Phase 2
